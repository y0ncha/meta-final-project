#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
RUNNER="$SCRIPT_DIR/run-gatling-container"

positive_int() {
  name="$1"
  value="$2"
  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$name must be a positive integer" >&2
      exit 2
      ;;
  esac
  if [ "$value" -le 0 ]; then
    printf '%s\n' "$name must be greater than 0" >&2
    exit 2
  fi
}

bool_value() {
  name="$1"
  value="$2"
  case "$value" in
    true|false) ;;
    *)
      printf '%s\n' "$name must be true or false" >&2
      exit 2
      ;;
  esac
}

GATLING_MAX_BASE_USERS="${GATLING_MAX_BASE_USERS:-${GATLING_MAX_BASE_USERS_PER_SEC:-${GATLING_MAX_START_USERS_PER_SEC:-5}}}"
GATLING_MAX_STEP_USERS="${GATLING_MAX_STEP_USERS:-${GATLING_MAX_STEP_USERS_PER_SEC:-5}}"
GATLING_MAX_DURATION_SECONDS="${GATLING_MAX_DURATION_SECONDS:-${GATLING_MAX_LEVEL_SECONDS:-30}}"
GATLING_MAX_SINGLE_LEVEL_MODE="${GATLING_MAX_SINGLE_LEVEL_MODE:-true}"
GATLING_MAX_DISCOVERY_ATTEMPTS="${GATLING_MAX_DISCOVERY_ATTEMPTS:-3}"
GATLING_MAX_LEVEL_COUNT="${GATLING_MAX_LEVEL_COUNT:-10}"
GATLING_MAX_START_USERS="${GATLING_MAX_START_USERS:-${GATLING_MAX_START_USERS_PER_SEC:-$GATLING_MAX_BASE_USERS}}"

positive_int GATLING_MAX_BASE_USERS "$GATLING_MAX_BASE_USERS"
positive_int GATLING_MAX_STEP_USERS "$GATLING_MAX_STEP_USERS"
positive_int GATLING_MAX_DURATION_SECONDS "$GATLING_MAX_DURATION_SECONDS"
bool_value GATLING_MAX_SINGLE_LEVEL_MODE "$GATLING_MAX_SINGLE_LEVEL_MODE"
positive_int GATLING_MAX_DISCOVERY_ATTEMPTS "$GATLING_MAX_DISCOVERY_ATTEMPTS"
positive_int GATLING_MAX_START_USERS "$GATLING_MAX_START_USERS"
positive_int GATLING_MAX_STEP_USERS "$GATLING_MAX_STEP_USERS"
positive_int GATLING_MAX_LEVEL_COUNT "$GATLING_MAX_LEVEL_COUNT"

if [ -z "${GATLING_MAX_LIMIT_USERS:-}" ]; then
  GATLING_MAX_LIMIT_USERS="${GATLING_MAX_LIMIT_USERS_PER_SEC:-}"
fi
if [ -z "$GATLING_MAX_LIMIT_USERS" ]; then
  total_legacy_levels=$((GATLING_MAX_LEVEL_COUNT * GATLING_MAX_DISCOVERY_ATTEMPTS))
  GATLING_MAX_LIMIT_USERS=$((GATLING_MAX_BASE_USERS + (GATLING_MAX_STEP_USERS * (total_legacy_levels - 1))))
fi
positive_int GATLING_MAX_LIMIT_USERS "$GATLING_MAX_LIMIT_USERS"

if [ "$GATLING_MAX_LIMIT_USERS" -lt "$GATLING_MAX_BASE_USERS" ]; then
  printf '%s\n' 'GATLING_MAX_LIMIT_USERS must be greater than or equal to GATLING_MAX_BASE_USERS' >&2
  exit 2
fi

OUTPUT_DIR="output/gatling/max-limit"
DISCOVERY_LOG="$OUTPUT_DIR/raw/max-limit-discovery.log"
mkdir -p "$OUTPUT_DIR/raw"
: > "$DISCOVERY_LOG"

log() {
  printf '%s\n' "$*" | tee -a "$DISCOVERY_LOG"
}

run_gatling_level() {
  users="$1"

  env \
    GATLING_RUN_TYPE=max-limit \
    GATLING_MAX_USERS="$users" \
    GATLING_MAX_DURATION_SECONDS="$GATLING_MAX_DURATION_SECONDS" \
    "$RUNNER"
}

has_gatling_report() {
  [ -s "$OUTPUT_DIR/index.html" ] && [ -s "$OUTPUT_DIR/max-limit-run.log" ]
}

attempt=1
current_start="$GATLING_MAX_START_USERS"
highest_passing_level=""

if [ "$GATLING_MAX_SINGLE_LEVEL_MODE" = true ]; then
  current_start="$GATLING_MAX_BASE_USERS"
  log "Max-limit single-level discovery: ${GATLING_MAX_BASE_USERS}-${GATLING_MAX_LIMIT_USERS} virtual users, step ${GATLING_MAX_STEP_USERS}, duration ${GATLING_MAX_DURATION_SECONDS}s"

  while [ "$current_start" -le "$GATLING_MAX_LIMIT_USERS" ]; do
    log "Max-limit testing level ${current_start} virtual users."

    set +e
    run_gatling_level "$current_start"
    status=$?
    set -e

    if [ "$status" -eq 0 ]; then
      highest_passing_level="$current_start"
      log "Max-limit level ${current_start} virtual users passed."
      current_start=$((current_start + GATLING_MAX_STEP_USERS))
      continue
    fi

    if has_gatling_report; then
      if [ -n "$highest_passing_level" ]; then
        log "Max-limit highest passing tested level: ${highest_passing_level} virtual users."
      else
        log "No passing tested level found before first failure."
      fi
      log "Max-limit first failing tested level: ${current_start} virtual users."
      log "Treating this assertion failure as successful max-limit discovery evidence."
      exit 0
    fi

    log "Max-limit level ${current_start} virtual users failed before a usable Gatling report was created."
    exit "$status"
  done

  log "No failing threshold found. Result is a tested lower bound through ${highest_passing_level} virtual users."
  exit 0
fi

while [ "$attempt" -le "$GATLING_MAX_DISCOVERY_ATTEMPTS" ]; do
  highest_level=$((current_start + (GATLING_MAX_STEP_USERS * (GATLING_MAX_LEVEL_COUNT - 1))))

  log "Max-limit attempt $attempt/$GATLING_MAX_DISCOVERY_ATTEMPTS: ${current_start}-${highest_level} virtual users"

  set +e
  run_gatling_level "$current_start"
  status=$?
  set -e

  if [ "$status" -eq 0 ]; then
    log "Max-limit attempt $attempt passed through ${current_start} virtual users."
    if [ "$attempt" -eq "$GATLING_MAX_DISCOVERY_ATTEMPTS" ]; then
      log "No failing threshold found. Result is a tested lower bound through ${current_start} virtual users."
      exit 0
    fi
    current_start=$((current_start + GATLING_MAX_STEP_USERS))
    attempt=$((attempt + 1))
    continue
  fi

  if has_gatling_report; then
    log "Max-limit attempt $attempt crossed a Gatling threshold at ${current_start} virtual users."
    log "Treating this assertion failure as successful max-limit discovery evidence."
    exit 0
  fi

  log "Max-limit attempt $attempt failed before a usable Gatling report was created."
  exit "$status"
done
