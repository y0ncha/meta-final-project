#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
RUNNER="$SCRIPT_DIR/run-gatling-container"
APP_BASE_URL="${APP_BASE_URL:-http://tomcat:8080/yonatan-csasznik-yoed-halberstam-niv-levin/}"

positive_int() {
  name="$1"
  value="$2"
  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$name must be a positive integer" >&2
      exit 2
      ;;
  esac
  if [ "$value" -le 0 ]; then
    printf '%s\n' "$name must be greater than 0" >&2
    exit 2
  fi
}

non_negative_int() {
  name="$1"
  value="$2"
  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$name must be a non-negative integer" >&2
      exit 2
      ;;
  esac
}

GATLING_MAX_USERS="${GATLING_MAX_USERS:-${GATLING_MAX_START_USERS_PER_SEC:-8250}}"
GATLING_MAX_BASE_USERS="${GATLING_MAX_START_USERS_PER_SEC:-${GATLING_MAX_BASE_USERS:-${GATLING_MAX_BASE_USERS_PER_SEC:-$GATLING_MAX_USERS}}}"
GATLING_MAX_STEP_USERS="${GATLING_MAX_STEP_USERS_PER_SEC:-${GATLING_MAX_STEP_USERS:-50}}"
GATLING_MAX_DURATION_SECONDS="${GATLING_MAX_DURATION_SECONDS:-${GATLING_MAX_LEVEL_SECONDS:-10}}"
GATLING_MAX_RAMP_SECONDS="${GATLING_MAX_RAMP_SECONDS:-0}"
GATLING_CONSOLE_MODE="${GATLING_CONSOLE_MODE:-summary}"
GATLING_RESTART_TOMCAT_BEFORE_RUN="${GATLING_RESTART_TOMCAT_BEFORE_RUN:-false}"

positive_int GATLING_MAX_START_USERS_PER_SEC "$GATLING_MAX_BASE_USERS"
positive_int GATLING_MAX_STEP_USERS_PER_SEC "$GATLING_MAX_STEP_USERS"
positive_int GATLING_MAX_DURATION_SECONDS "$GATLING_MAX_DURATION_SECONDS"
non_negative_int GATLING_MAX_RAMP_SECONDS "$GATLING_MAX_RAMP_SECONDS"
case "$GATLING_CONSOLE_MODE" in
  full|summary) ;;
  *)
    printf '%s\n' 'GATLING_CONSOLE_MODE must be full or summary' >&2
    exit 2
    ;;
esac
case "$GATLING_RESTART_TOMCAT_BEFORE_RUN" in
  1|true|TRUE|yes|YES|on|ON|0|false|FALSE|no|NO|off|OFF) ;;
  *)
    printf '%s\n' 'GATLING_RESTART_TOMCAT_BEFORE_RUN must be true or false' >&2
    exit 2
    ;;
esac

GATLING_MAX_LIMIT_USERS="${GATLING_MAX_END_USERS_PER_SEC:-${GATLING_MAX_LIMIT_USERS:-${GATLING_MAX_LIMIT_USERS_PER_SEC:-}}}"
if [ -z "$GATLING_MAX_LIMIT_USERS" ]; then
  GATLING_MAX_LIMIT_USERS="8350"
fi
positive_int GATLING_MAX_END_USERS_PER_SEC "$GATLING_MAX_LIMIT_USERS"

if [ "$GATLING_MAX_LIMIT_USERS" -lt "$GATLING_MAX_BASE_USERS" ]; then
  printf '%s\n' 'GATLING_MAX_END_USERS_PER_SEC must be greater than or equal to GATLING_MAX_START_USERS_PER_SEC' >&2
  exit 2
fi

OUTPUT_DIR="output/gatling/max-limit"
DISCOVERY_LOG="$OUTPUT_DIR/raw/max-limit-discovery.log"
mkdir -p "$OUTPUT_DIR/raw"
: > "$DISCOVERY_LOG"

write_discovery_log() {
  printf '%s\n' "$*" >> "$DISCOVERY_LOG"
}

summary_log() {
  write_discovery_log "$*"
}

restart_log() {
  write_discovery_log "$*"
  printf '%s\n' "$*"
}

final_summary_log() {
  write_discovery_log "$*"
  printf '%s\n' "$*"
}

app_base_host() {
  without_scheme="$APP_BASE_URL"
  case "$without_scheme" in
    *://*) without_scheme=${without_scheme#*://} ;;
  esac
  host_port=${without_scheme%%/*}
  case "$host_port" in
    \[*\]*)
      host=${host_port#\[}
      host=${host%%\]*}
      ;;
    *)
      host=${host_port%%:*}
      ;;
  esac
  printf '%s\n' "$host"
}

is_truthy() {
  case "$1" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

is_local_tomcat_target() {
  case "$1" in
    tomcat|meta-tomcat|localhost|127.0.0.1|0.0.0.0|::1) return 0 ;;
    *) return 1 ;;
  esac
}

restart_tomcat_before_run() {
  if ! is_truthy "$GATLING_RESTART_TOMCAT_BEFORE_RUN"; then
    return 0
  fi

  target_host=$(app_base_host)
  if is_local_tomcat_target "$target_host"; then
    restart_log "Tomcat restart requested before Gatling: local Compose target from APP_BASE_URL=${APP_BASE_URL}"
    (cd "$PROJECT_ROOT" && docker compose restart tomcat >/dev/null)
  else
    printf '%s\n' 'Remote Tomcat restart before Gatling is intentionally unsupported. Restart the public EC2 Tomcat manually, then rerun without GATLING_RESTART_TOMCAT_BEFORE_RUN=true.' >&2
    exit 2
  fi
  restart_log 'Tomcat restart completed before Gatling.'
}

print_test_summary() {
  result="$1"
  highest_passing="$2"
  first_failing="$3"

  final_summary_log "Max-limit test summary:"
  final_summary_log "  app base URL: ${APP_BASE_URL}"
  final_summary_log "  parameters: range ${GATLING_MAX_BASE_USERS}-${GATLING_MAX_LIMIT_USERS} users/sec | step ${GATLING_MAX_STEP_USERS} users/sec | duration ${GATLING_MAX_DURATION_SECONDS}s/level | ramp ${GATLING_MAX_RAMP_SECONDS}s"
  if [ "$result" = "tested lower bound; no failing users/sec level found" ]; then
    final_summary_log "  key result: tested lower bound | no failing users/sec level found"
  elif [ -n "$highest_passing" ] && [ -n "$first_failing" ]; then
    final_summary_log "  key result: highest passing ${highest_passing} users/sec | first failing ${first_failing} users/sec"
  else
    final_summary_log "  key result: first KO observed | missing: boundary levels were not parsed from simulation.log"
  fi
}

level_at_offset_ms() {
  offset_ms="$1"
  level="$GATLING_MAX_BASE_USERS"
  previous_level=''
  elapsed_ms=0
  hold_ms=$((GATLING_MAX_DURATION_SECONDS * 1000))
  ramp_ms=$((GATLING_MAX_RAMP_SECONDS * 1000))

  if [ "$ramp_ms" -gt 0 ]; then
    elapsed_ms=$((elapsed_ms + ramp_ms))
    if [ "$offset_ms" -lt "$elapsed_ms" ]; then
      printf '%s|%s\n' "$previous_level" "$level"
      return 0
    fi
  fi

  while :; do
    elapsed_ms=$((elapsed_ms + hold_ms))
    if [ "$offset_ms" -lt "$elapsed_ms" ]; then
      printf '%s|%s\n' "$previous_level" "$level"
      return 0
    fi
    if [ "$level" -eq "$GATLING_MAX_LIMIT_USERS" ]; then
      printf '%s|%s\n' "$previous_level" "$level"
      return 0
    fi
    next_level=$((level + GATLING_MAX_STEP_USERS))
    if [ "$next_level" -gt "$GATLING_MAX_LIMIT_USERS" ]; then
      next_level="$GATLING_MAX_LIMIT_USERS"
    fi
    if [ "$ramp_ms" -gt 0 ]; then
      elapsed_ms=$((elapsed_ms + ramp_ms))
      if [ "$offset_ms" -lt "$elapsed_ms" ]; then
        printf '%s|%s\n' "$level" "$next_level"
        return 0
      fi
    fi
    previous_level="$level"
    level="$next_level"
  done
}

failure_levels_from_simulation_log() {
  simulation_log="$OUTPUT_DIR/simulation.log"
  if [ ! -s "$simulation_log" ]; then
    return 1
  fi

  first_ko_offset_ms=$(
    awk -F '	' '
      $1 == "RUN" && run == "" {
        run = $4
      }
      $1 == "REQUEST" && $7 == "KO" {
        if (first == "" || $5 < first) {
          first = $5
        }
      }
      END {
        if (run != "" && first != "") {
          print first - run
        } else {
          exit 1
        }
      }
    ' "$simulation_log"
  ) || return 1

  case "$first_ko_offset_ms" in
    ''|*[!0-9-]*)
      return 1
      ;;
  esac
  if [ "$first_ko_offset_ms" -lt 0 ]; then
    first_ko_offset_ms=0
  fi

  level_at_offset_ms "$first_ko_offset_ms"
}

run_gatling_staircase() {
  env \
    GATLING_RUN_TYPE=max-limit \
    APP_BASE_URL="$APP_BASE_URL" \
    GATLING_MAX_DISCOVERY_WRAPPER=1 \
    GATLING_MAX_BASE_USERS="$GATLING_MAX_BASE_USERS" \
    GATLING_MAX_STEP_USERS="$GATLING_MAX_STEP_USERS" \
    GATLING_MAX_LIMIT_USERS="$GATLING_MAX_LIMIT_USERS" \
    GATLING_MAX_DURATION_SECONDS="$GATLING_MAX_DURATION_SECONDS" \
    GATLING_MAX_RAMP_SECONDS="$GATLING_MAX_RAMP_SECONDS" \
    "$RUNNER"
}

has_gatling_report() {
  [ -s "$OUTPUT_DIR/index.html" ] && [ -s "$OUTPUT_DIR/max-limit-run.log" ]
}

write_level_schedule() {
  level="$GATLING_MAX_BASE_USERS"
  starts_at=0
  if [ "$GATLING_MAX_RAMP_SECONDS" -gt 0 ]; then
    ends_at="$GATLING_MAX_RAMP_SECONDS"
    summary_log "ramp schedule: 0-${level} users/sec | report time window: ${starts_at}-${ends_at}s"
    starts_at="$ends_at"
  fi
  while :; do
    ends_at=$((starts_at + GATLING_MAX_DURATION_SECONDS))
    summary_log "level schedule: ${level} users/sec | report time window: ${starts_at}-${ends_at}s"
    if [ "$level" -eq "$GATLING_MAX_LIMIT_USERS" ]; then
      break
    fi
    next_level=$((level + GATLING_MAX_STEP_USERS))
    if [ "$next_level" -gt "$GATLING_MAX_LIMIT_USERS" ]; then
      next_level="$GATLING_MAX_LIMIT_USERS"
    fi
    if [ "$GATLING_MAX_RAMP_SECONDS" -gt 0 ]; then
      ramp_starts_at="$ends_at"
      ramp_ends_at=$((ramp_starts_at + GATLING_MAX_RAMP_SECONDS))
      summary_log "ramp schedule: ${level}-${next_level} users/sec | report time window: ${ramp_starts_at}-${ramp_ends_at}s"
      starts_at="$ramp_ends_at"
    else
      starts_at="$ends_at"
    fi
    level="$next_level"
  done
}

summary_log "max limit staircase started : ${GATLING_MAX_BASE_USERS}-${GATLING_MAX_LIMIT_USERS} users/sec | step: ${GATLING_MAX_STEP_USERS} users/sec | duration: ${GATLING_MAX_DURATION_SECONDS}s per level | ramp: ${GATLING_MAX_RAMP_SECONDS}s"
summary_log "command parameters: GATLING_RUN_TYPE=max-limit APP_BASE_URL=${APP_BASE_URL} GATLING_MAX_START_USERS_PER_SEC=${GATLING_MAX_BASE_USERS} GATLING_MAX_STEP_USERS_PER_SEC=${GATLING_MAX_STEP_USERS} GATLING_MAX_END_USERS_PER_SEC=${GATLING_MAX_LIMIT_USERS} GATLING_MAX_DURATION_SECONDS=${GATLING_MAX_DURATION_SECONDS} GATLING_MAX_RAMP_SECONDS=${GATLING_MAX_RAMP_SECONDS}"
restart_tomcat_before_run
write_level_schedule

set +e
run_gatling_staircase
status=$?
set -e

if [ "$status" -ne 0 ] && ! has_gatling_report; then
  printf '%s\n' 'Max-limit staircase failed before a usable Gatling report was created.' >&2
  summary_log 'Max-limit staircase failed before a usable Gatling report was created.'
  exit "$status"
fi

if [ "$status" -eq 0 ]; then
  print_test_summary "tested lower bound; no failing level found" "" ""
  exit 0
fi

failure_levels=$(failure_levels_from_simulation_log || true)
if [ -n "$failure_levels" ]; then
  highest_passing=$(printf '%s\n' "$failure_levels" | cut -d '|' -f 1)
  first_failing=$(printf '%s\n' "$failure_levels" | cut -d '|' -f 2)
else
  highest_passing=''
  first_failing=''
fi

print_test_summary "inspect staircase report for first KO level" "$highest_passing" "$first_failing"
exit 0
