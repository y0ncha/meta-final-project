#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
RUNNER="$SCRIPT_DIR/run-gatling-container"

positive_int() {
  name="$1"
  value="$2"
  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$name must be a positive integer" >&2
      exit 2
      ;;
  esac
  if [ "$value" -le 0 ]; then
    printf '%s\n' "$name must be greater than 0" >&2
    exit 2
  fi
}

GATLING_MAX_USERS="${GATLING_MAX_USERS:-${GATLING_MAX_START_USERS_PER_SEC:-5}}"
GATLING_MAX_BASE_USERS="${GATLING_MAX_BASE_USERS:-${GATLING_MAX_BASE_USERS_PER_SEC:-${GATLING_MAX_START_USERS_PER_SEC:-$GATLING_MAX_USERS}}}"
GATLING_MAX_STEP_USERS="${GATLING_MAX_STEP_USERS:-${GATLING_MAX_STEP_USERS_PER_SEC:-5}}"
GATLING_MAX_DURATION_SECONDS="${GATLING_MAX_DURATION_SECONDS:-${GATLING_MAX_LEVEL_SECONDS:-30}}"
GATLING_CONSOLE_MODE="${GATLING_CONSOLE_MODE:-full}"

positive_int GATLING_MAX_BASE_USERS "$GATLING_MAX_BASE_USERS"
positive_int GATLING_MAX_STEP_USERS "$GATLING_MAX_STEP_USERS"
positive_int GATLING_MAX_DURATION_SECONDS "$GATLING_MAX_DURATION_SECONDS"
case "$GATLING_CONSOLE_MODE" in
  full|summary) ;;
  *)
    printf '%s\n' 'GATLING_CONSOLE_MODE must be full or summary' >&2
    exit 2
    ;;
esac

if [ -z "${GATLING_MAX_LIMIT_USERS:-}" ]; then
  GATLING_MAX_LIMIT_USERS="${GATLING_MAX_LIMIT_USERS_PER_SEC:-}"
fi
if [ -z "$GATLING_MAX_LIMIT_USERS" ]; then
  GATLING_MAX_LIMIT_USERS="$GATLING_MAX_BASE_USERS"
fi
positive_int GATLING_MAX_LIMIT_USERS "$GATLING_MAX_LIMIT_USERS"

if [ "$GATLING_MAX_LIMIT_USERS" -lt "$GATLING_MAX_BASE_USERS" ]; then
  printf '%s\n' 'GATLING_MAX_LIMIT_USERS must be greater than or equal to GATLING_MAX_BASE_USERS' >&2
  exit 2
fi

OUTPUT_DIR="output/gatling/max-limit"
DISCOVERY_LOG="$OUTPUT_DIR/raw/max-limit-discovery.log"
mkdir -p "$OUTPUT_DIR/raw"
: > "$DISCOVERY_LOG"

write_discovery_log() {
  printf '%s\n' "$*" >> "$DISCOVERY_LOG"
}

summary_log() {
  write_discovery_log "$*"
}

final_summary_log() {
  write_discovery_log "$*"
  printf '%s\n' "$*"
}

print_test_summary() {
  result="$1"
  highest_passing="$2"
  first_failing="$3"

  final_summary_log "Max-limit test summary:"
  final_summary_log "  tested range: ${GATLING_MAX_BASE_USERS}-${GATLING_MAX_LIMIT_USERS} virtual users"
  final_summary_log "  step: ${GATLING_MAX_STEP_USERS} virtual users"
  final_summary_log "  duration: ${GATLING_MAX_DURATION_SECONDS}s per level"
  final_summary_log "  cutoff rule: highest tested level with KO=0; first failing level has KO>0"
  if [ -n "$highest_passing" ]; then
    final_summary_log "  highest passing tested level: $highest_passing"
  else
    final_summary_log "  highest passing tested level: inspect staircase report"
  fi
  if [ -n "$first_failing" ]; then
    final_summary_log "  first failing tested level: $first_failing"
  else
    final_summary_log "  first failing tested level: inspect staircase report"
  fi
  final_summary_log "  result: $result"
  if [ -s "$OUTPUT_DIR/index.html" ]; then
    final_summary_log "  staircase Gatling report: $OUTPUT_DIR/index.html"
  fi
  final_summary_log "  full discovery log: $DISCOVERY_LOG"
}

run_gatling_staircase() {
  env \
    GATLING_RUN_TYPE=max-limit \
    GATLING_MAX_DISCOVERY_WRAPPER=1 \
    GATLING_MAX_BASE_USERS="$GATLING_MAX_BASE_USERS" \
    GATLING_MAX_STEP_USERS="$GATLING_MAX_STEP_USERS" \
    GATLING_MAX_LIMIT_USERS="$GATLING_MAX_LIMIT_USERS" \
    GATLING_MAX_DURATION_SECONDS="$GATLING_MAX_DURATION_SECONDS" \
    "$RUNNER"
}

has_gatling_report() {
  [ -s "$OUTPUT_DIR/index.html" ] && [ -s "$OUTPUT_DIR/max-limit-run.log" ]
}

write_level_schedule() {
  level="$GATLING_MAX_BASE_USERS"
  index=0
  while :; do
    starts_at=$((index * GATLING_MAX_DURATION_SECONDS))
    ends_at=$(((index + 1) * GATLING_MAX_DURATION_SECONDS))
    summary_log "level schedule: ${level} virtual users | report time window: ${starts_at}-${ends_at}s"
    if [ "$level" -eq "$GATLING_MAX_LIMIT_USERS" ]; then
      break
    fi
    next_level=$((level + GATLING_MAX_STEP_USERS))
    if [ "$next_level" -gt "$GATLING_MAX_LIMIT_USERS" ]; then
      level="$GATLING_MAX_LIMIT_USERS"
    else
      level="$next_level"
    fi
    index=$((index + 1))
  done
}

summary_log "max limit staircase started : ${GATLING_MAX_BASE_USERS}-${GATLING_MAX_LIMIT_USERS} virtual users | step: ${GATLING_MAX_STEP_USERS} virtual users | duration: ${GATLING_MAX_DURATION_SECONDS}s per level"
summary_log "command parameters: GATLING_RUN_TYPE=max-limit GATLING_MAX_BASE_USERS=${GATLING_MAX_BASE_USERS} GATLING_MAX_STEP_USERS=${GATLING_MAX_STEP_USERS} GATLING_MAX_LIMIT_USERS=${GATLING_MAX_LIMIT_USERS} GATLING_MAX_DURATION_SECONDS=${GATLING_MAX_DURATION_SECONDS}"
write_level_schedule

set +e
run_gatling_staircase
status=$?
set -e

if [ "$status" -ne 0 ] && ! has_gatling_report; then
  printf '%s\n' 'Max-limit staircase failed before a usable Gatling report was created.' >&2
  summary_log 'Max-limit staircase failed before a usable Gatling report was created.'
  exit "$status"
fi

if [ "$status" -eq 0 ]; then
  print_test_summary "tested lower bound; no failing level found" "" ""
  exit 0
fi

print_test_summary "inspect staircase report for first KO level" "" ""
exit 0
