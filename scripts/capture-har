#!/usr/bin/env sh
set -eu

# Optional environment variables:
# PLAYWRIGHT_IMAGE, APP_BASE_URL, HAR_PATH, LOG_FILE, HAR_CONTAINER_NAME,
# HAR_DOCKER_NETWORK, HAR_DOCKER_PIPELINE.

PROJECT_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd -P)
cd "$PROJECT_ROOT"

PLAYWRIGHT_IMAGE="${PLAYWRIGHT_IMAGE:-mcr.microsoft.com/playwright:v1.60.0-noble}"
APP_BASE_URL="${APP_BASE_URL:-http://tomcat:8080/meta/}"
HAR_PATH="${HAR_PATH:-output/har/meta-functional-flow.har}"
LOG_FILE="${LOG_FILE:-output/har/07-har-capture.log}"
HAR_CONTAINER_NAME="${HAR_CONTAINER_NAME:-meta-har-${BUILD_NUMBER:-local}}"
HAR_DOCKER_NETWORK="${HAR_DOCKER_NETWORK:-meta}"
HAR_DOCKER_PIPELINE="${HAR_DOCKER_PIPELINE:-0}"

mkdir -p output/har

run_and_log() {
  set +e
  "$@" > "$LOG_FILE" 2>&1
  status=$?
  set -e
  cat "$LOG_FILE"
  return "$status"
}

case "$HAR_DOCKER_PIPELINE" in
  0|1) ;;
  *)
    printf '%s\n' 'HAR_DOCKER_PIPELINE must be 0 or 1' >&2
    exit 2
    ;;
esac

if [ "$HAR_DOCKER_PIPELINE" = "1" ]; then
  export APP_BASE_URL HAR_PATH
  export CI=true
  run_and_log /bin/bash -lc 'npm ci && node tests/playwright/capture-har.js'
else
  if ! command -v docker >/dev/null 2>&1; then
    printf '%s\n' 'Docker is required to capture HAR in the Playwright container.' >&2
    exit 127
  fi

  run_and_log docker run --rm \
    --name "$HAR_CONTAINER_NAME" \
    --network "$HAR_DOCKER_NETWORK" \
    -v "$PROJECT_ROOT:/work" \
    -w /work \
    -e APP_BASE_URL="$APP_BASE_URL" \
    -e HAR_PATH="$HAR_PATH" \
    -e CI=true \
    "$PLAYWRIGHT_IMAGE" \
    /bin/bash -lc 'npm ci && node tests/playwright/capture-har.js'
fi

printf '%s\n' 'HAR evidence:'
printf '%s\n' "  $LOG_FILE"
printf '%s\n' "  $HAR_PATH"
