#!/usr/bin/env sh
set -eu

# Optional environment variables:
# PLAYWRIGHT_IMAGE, GATLING_PDF_CONTAINER_NAME, GATLING_PDF_REQUIRE_ALL.

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
cd "$PROJECT_ROOT"

PLAYWRIGHT_IMAGE="${PLAYWRIGHT_IMAGE:-mcr.microsoft.com/playwright:v1.60.0-noble}"
GATLING_PDF_CONTAINER_NAME="${GATLING_PDF_CONTAINER_NAME:-meta-gatling-pdf-${BUILD_NUMBER:-local}}"
GATLING_PDF_REQUIRE_ALL="${GATLING_PDF_REQUIRE_ALL:-true}"
LOG_FILE="output/gatling/export-pdfs.log"
PLAYWRIGHT_SERVICE="playwright-runner"

mkdir -p output/gatling

if ! command -v docker >/dev/null 2>&1; then
  printf '%s\n' 'docker is required to export Gatling PDFs' >&2
  exit 127
fi

run_and_log() {
  set +e
  "$@" > "$LOG_FILE" 2>&1
  status=$?
  set -e
  cat "$LOG_FILE"
  return "$status"
}

if [ -f /var/jenkins_home/config.xml ]; then
  PLAYWRIGHT_SERVICE="playwright-runner-jenkins"
fi

export PLAYWRIGHT_IMAGE

run_and_log docker compose --profile tools run --rm --no-deps \
  --name "$GATLING_PDF_CONTAINER_NAME" \
  -e CI=true \
  -e GATLING_PDF_REQUIRE_ALL="$GATLING_PDF_REQUIRE_ALL" \
  "$PLAYWRIGHT_SERVICE" \
  /bin/bash -lc 'npm ci && node tests/playwright/export-gatling-pdfs.js'

printf '%s\n' "Gatling PDF export complete. Log: $LOG_FILE"
