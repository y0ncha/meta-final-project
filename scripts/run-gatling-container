#!/usr/bin/env sh
set -eu

# Optional environment variables:
# GATLING_IMAGE, GATLING_PLATFORM, APP_BASE_URL, GATLING_CONTAINER_NAME,
# GATLING_SIMULATION_CLASS, GATLING_DOCKER_NETWORK, GATLING_DOCKER_PIPELINE,
# GATLING_BIN, GATLING_CONSOLE_MODE, GATLING_* virtual-user load values.

SCRIPT_DIR=$(dirname "$0")
PROJECT_ROOT=$(cd "$SCRIPT_DIR/.." && pwd -P)
cd "$PROJECT_ROOT"

GATLING_RUN_TYPE="${GATLING_RUN_TYPE:-}"
case "$GATLING_RUN_TYPE" in
  max-limit|load-5m|stress-5m) ;;
  *)
    printf '%s\n' 'GATLING_RUN_TYPE must be max-limit, load-5m, or stress-5m' >&2
    exit 2
    ;;
esac

GATLING_IMAGE="${GATLING_IMAGE:-denvazh/gatling:3.2.1}"
GATLING_PLATFORM="${GATLING_PLATFORM:-linux/amd64}"
APP_BASE_URL="${APP_BASE_URL:-http://tomcat:8080/yonatan-csasznik-yoed-halberstam-niv-levin/}"
GATLING_CONTAINER_NAME="${GATLING_CONTAINER_NAME:-meta-gatling-${GATLING_RUN_TYPE}-${BUILD_NUMBER:-local}}"
GATLING_DOCKER_NETWORK="${GATLING_DOCKER_NETWORK:-meta}"
GATLING_DOCKER_PIPELINE="${GATLING_DOCKER_PIPELINE:-0}"
GATLING_BIN="${GATLING_BIN:-}"
GATLING_CONSOLE_MODE="${GATLING_CONSOLE_MODE:-full}"
GATLING_LOAD_USERS="${GATLING_LOAD_USERS:-${GATLING_LOAD_USERS_PER_SEC:-5}}"
GATLING_STRESS_START_USERS="${GATLING_STRESS_START_USERS:-${GATLING_STRESS_START_USERS_PER_SEC:-10}}"
GATLING_STRESS_TARGET_USERS="${GATLING_STRESS_TARGET_USERS:-${GATLING_STRESS_TARGET_USERS_PER_SEC:-50}}"
GATLING_MAX_USERS="${GATLING_MAX_USERS:-${GATLING_MAX_START_USERS_PER_SEC:-5}}"
GATLING_MAX_BASE_USERS="${GATLING_MAX_BASE_USERS:-${GATLING_MAX_BASE_USERS_PER_SEC:-${GATLING_MAX_START_USERS_PER_SEC:-$GATLING_MAX_USERS}}}"
GATLING_MAX_STEP_USERS="${GATLING_MAX_STEP_USERS:-${GATLING_MAX_STEP_USERS_PER_SEC:-5}}"
GATLING_MAX_DURATION_SECONDS="${GATLING_MAX_DURATION_SECONDS:-${GATLING_MAX_LEVEL_SECONDS:-30}}"
GATLING_LOAD_DURATION_SECONDS=300
GATLING_STRESS_DURATION_SECONDS=300
SIMULATION_CLASS="${GATLING_SIMULATION_CLASS:-MetaSimulation}"

case "$GATLING_CONSOLE_MODE" in
  full|summary) ;;
  *)
    printf '%s\n' 'GATLING_CONSOLE_MODE must be full or summary' >&2
    exit 2
    ;;
esac
OUTPUT_DIR="output/gatling/$GATLING_RUN_TYPE"
RAW_DIR="$OUTPUT_DIR/raw"
LOG_FILE="$OUTPUT_DIR/${GATLING_RUN_TYPE}-run.log"

mkdir -p "$OUTPUT_DIR" "$RAW_DIR" output/gatling/screenshots
find "$OUTPUT_DIR" -mindepth 1 -maxdepth 1 ! -name raw -exec rm -rf {} +

print_gatling_log_excerpt() {
  grep -E '^(Simulation|Parsing log file|Generating reports|Reports generated|Assertions|All assertions|Please open)' "$LOG_FILE" || {
    printf '%s\n' "No Gatling summary lines matched; inspect $LOG_FILE"
  }
}

print_default_gatling_summary() {
  printf '%s\n' "Gatling console mode: summary. Full log saved to $LOG_FILE"
  awk '
    /^---- Global Information/ {
      found = 1
      block = $0 ORS
      next
    }
    found {
      block = block $0 ORS
    }
    END {
      if (!found) {
        exit 1
      }
      printf "%s", block
    }
  ' "$LOG_FILE"
}

print_test_parameters() {
  if [ "$GATLING_CONSOLE_MODE" = summary ]; then
    return 0
  fi

  case "$GATLING_RUN_TYPE" in
    load-5m)
      printf '%s\n' "load test started : ${GATLING_LOAD_USERS} virtual users | duration: ${GATLING_LOAD_DURATION_SECONDS}s"
      ;;
    stress-5m)
      printf '%s\n' "stress test started : ${GATLING_STRESS_START_USERS}-${GATLING_STRESS_TARGET_USERS} virtual users | duration: ${GATLING_STRESS_DURATION_SECONDS}s"
      ;;
    max-limit)
      if [ "${GATLING_MAX_DISCOVERY_WRAPPER:-0}" != "1" ]; then
        printf '%s\n' "max limit test started : ${GATLING_MAX_USERS} virtual users | duration: ${GATLING_MAX_DURATION_SECONDS}s"
      fi
      ;;
  esac
}

run_and_log() {
  set +e
  "$@" > "$LOG_FILE" 2>&1
  status=$?
  set -e
  case "$GATLING_CONSOLE_MODE" in
    full)
      cat "$LOG_FILE"
      ;;
    summary)
      if [ "$GATLING_RUN_TYPE" != "max-limit" ] || [ "$status" -ne 0 ]; then
        print_default_gatling_summary || print_gatling_log_excerpt
      fi
      ;;
  esac
  return "$status"
}

case "$GATLING_DOCKER_PIPELINE" in
  0|1) ;;
  *)
    printf '%s\n' 'GATLING_DOCKER_PIPELINE must be 0 or 1' >&2
    exit 2
    ;;
esac

print_test_parameters

if [ "$GATLING_DOCKER_PIPELINE" = "1" ]; then
  export APP_BASE_URL
  export GATLING_RUN_TYPE
  export GATLING_LOAD_USERS
  export GATLING_STRESS_START_USERS
  export GATLING_STRESS_TARGET_USERS
  export GATLING_MAX_USERS
  export GATLING_MAX_BASE_USERS
  export GATLING_MAX_STEP_USERS
  export GATLING_MAX_DURATION_SECONDS

  CONTAINER_PROJECT_ROOT="$PROJECT_ROOT"
  GATLING_CMD="$GATLING_BIN"
  if [ -z "$GATLING_CMD" ] && command -v gatling.sh >/dev/null 2>&1; then
    GATLING_CMD=$(command -v gatling.sh)
  fi
  for candidate in /opt/gatling/bin/gatling.sh /gatling/bin/gatling.sh; do
    if [ -z "$GATLING_CMD" ] && [ -x "$candidate" ]; then
      GATLING_CMD="$candidate"
    fi
  done
  if [ -z "$GATLING_CMD" ]; then
    printf '%s\n' 'Could not locate gatling.sh inside the Gatling container' >&2
    exit 127
  fi

  gatling_status=0
  run_and_log "$GATLING_CMD" \
    -sf "$CONTAINER_PROJECT_ROOT/src/gatling/user-files/simulations" \
    -rf "$CONTAINER_PROJECT_ROOT/$RAW_DIR" \
    -s "$SIMULATION_CLASS" || gatling_status=$?
else
  if ! command -v docker >/dev/null 2>&1; then
    printf '%s\n' 'docker is required to run Gatling' >&2
    exit 127
  fi

  gatling_status=0
  run_and_log docker run --rm \
    --platform "$GATLING_PLATFORM" \
    --name "$GATLING_CONTAINER_NAME" \
    --network "$GATLING_DOCKER_NETWORK" \
    -v "$PROJECT_ROOT:/work" \
    -w /work \
    -e APP_BASE_URL="$APP_BASE_URL" \
    -e GATLING_RUN_TYPE="$GATLING_RUN_TYPE" \
    -e GATLING_LOAD_USERS="$GATLING_LOAD_USERS" \
    -e GATLING_STRESS_START_USERS="$GATLING_STRESS_START_USERS" \
    -e GATLING_STRESS_TARGET_USERS="$GATLING_STRESS_TARGET_USERS" \
    -e GATLING_MAX_USERS="$GATLING_MAX_USERS" \
    -e GATLING_MAX_BASE_USERS="$GATLING_MAX_BASE_USERS" \
    -e GATLING_MAX_STEP_USERS="$GATLING_MAX_STEP_USERS" \
    -e GATLING_MAX_DURATION_SECONDS="$GATLING_MAX_DURATION_SECONDS" \
    "$GATLING_IMAGE" \
    -sf /work/src/gatling/user-files/simulations \
    -rf "/work/$RAW_DIR" \
    -s "$SIMULATION_CLASS" || gatling_status=$?
fi

REPORT_INDEX=$(find "$RAW_DIR" -mindepth 2 -maxdepth 2 -name index.html -type f -print | sort | tail -n 1)
if [ -z "$REPORT_INDEX" ]; then
  if [ "$gatling_status" -ne 0 ]; then
    printf '%s\n' "Gatling exited with status $gatling_status and no report index.html was created under $RAW_DIR" >&2
    exit "$gatling_status"
  fi
  printf '%s\n' "Gatling report index.html was not created under $RAW_DIR" >&2
  exit 1
fi

REPORT_DIR=$(dirname "$REPORT_INDEX")
if [ ! -s "$REPORT_DIR/index.html" ]; then
  printf '%s\n' "Gatling report index.html was not created under $RAW_DIR" >&2
  exit 1
fi

cp -R "$REPORT_DIR"/. "$OUTPUT_DIR"/
test -s "$OUTPUT_DIR/index.html"
test -s "$LOG_FILE"

if [ "$GATLING_CONSOLE_MODE" != summary ] || [ "$GATLING_RUN_TYPE" != max-limit ]; then
  printf '%s\n' 'Gatling evidence:'
  printf '%s\n' "  $LOG_FILE"
  printf '%s\n' "  $OUTPUT_DIR/index.html"
  printf '%s\n' "  $RAW_DIR"
fi

if [ "$gatling_status" -ne 0 ]; then
  if [ "$GATLING_CONSOLE_MODE" != summary ] || [ "$GATLING_RUN_TYPE" != max-limit ]; then
    printf '%s\n' "Gatling exited with status $gatling_status after report normalization" >&2
  fi
  exit "$gatling_status"
fi
