# Environment variables for Docker Compose configuration
COMPOSE_PROJECT_NAME=meta
TOMCAT_IMAGE=tomcat:8.5.100-jdk17-temurin
JENKINS_IMAGE=jenkins/jenkins:2.528.1-lts-jdk21
TOMCAT_HOST_PORT=8080
JENKINS_HOST_PORT=8081

# Application target for local scripts when this file is copied to `.env`
# and exported by the shell. Local Docker-runner default:
APP_BASE_URL=http://tomcat:8080/yonatan-csasznik-yoed-halberstam-niv-levin/
# EC2 public-host value for Plan 11 evidence:
# APP_BASE_URL=http://51.84.219.74:8080/yonatan-csasznik-yoed-halberstam-niv-levin/

# Docker restart policy for the Tomcat container.
# Local default: no
# EC2 public-host value: unless-stopped
TOMCAT_RESTART_POLICY=no
